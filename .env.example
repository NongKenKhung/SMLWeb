# ===== Runtime =====
NODE_ENV=production
PORT=3000

# ===== Database (required) =====
# docker-compose binds these → DATABASE_URL. Use a STRONG password before
# deploying to anything reachable from a network.
POSTGRES_USER=smluser
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=smartcitylab
DATABASE_URL=postgres://smluser:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/smartcitylab
# PGSSLMODE=require   # uncomment for managed providers (RDS, Neon, Supabase)
# PG_POOL_MAX=10

# ===== pgAdmin =====
# UI at http://localhost:5050 — bound to loopback only by default.
# Tunnel via SSH/VPN for remote admin.
PGADMIN_DEFAULT_EMAIL=you@example.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME

# ===== Auth / Session =====
TOKEN_TTL_DAYS=30
TOKEN_FILE=./.tokens.json
LOGIN_RATE_LIMIT=10

# ===== Reverse proxy =====
# Set to 1 if behind nginx/Caddy/Cloudflare so req.ip + rate-limit per-IP work.
TRUST_PROXY=0

# ===== SMTP (optional — for meeting invitations + future notifications) =====
# When set, creating/editing/deleting a kind='meeting' task auto-sends an
# iCalendar invitation. Gmail: enable 2-Step Verification + create an App
# Password at https://myaccount.google.com/apppasswords (16 chars).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app-password-16-chars
SMTP_FROM="Your Lab <you@gmail.com>"
# SMTP_SECURE=true   # true for port 465; false (default) for STARTTLS on 587

# ===== ASR / AI =====
# Override only if running on different hardware. Defaults are tuned for
# RTX 4060 8GB; see docker-compose.yml.
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16
# WHISPER_BATCH_SIZE=8
# WHISPER_LANG=th
# OLLAMA_MODEL=scb10x/llama3.2-typhoon2-3b-instruct
