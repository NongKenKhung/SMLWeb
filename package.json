{
  "name": "sml-web",
  "version": "1.0.0",
  "description": "Smart City Lab - Member & Task Management Web App",
  "main": "backend/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node backend/server.js",
    "start:prod": "NODE_ENV=production node backend/server.js",
    "dev": "node backend/server.js",
    "seed": "node backend/seed.js",
    "reset": "node backend/seed.js --reset",
    "mock-files": "node backend/mock_files.js",
    "test:api": "node backend/test_api.js",
    "pm2:start": "pm2 start backend/ecosystem.config.js",
    "pm2:reload": "pm2 reload backend/ecosystem.config.js",
    "pm2:stop": "pm2 stop backend/ecosystem.config.js",
    "pm2:logs": "pm2 logs sml-web",
    "compose:up": "docker compose up -d postgres pgadmin app",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f app",
    "docker:build": "docker build -t sml-web:latest .",
    "docker:run": "docker run --rm -p 3000:3000 -v \"$PWD/uploads:/app/uploads\" --env-file .env sml-web:latest"
  },
  "dependencies": {
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.2.0",
    "multer": "^2.0.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "ws": "^8.18.0"
  }
}
